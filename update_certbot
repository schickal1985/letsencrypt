#!/bin/bash
# Hauptskript zum Erneuern/Holen von Let's Encrypt Zertifikaten (PARALLELE ISOLIERTE VERSION)
# Version: 1.0

# Prüfe auf Root Rechte
if [ "$EUID" -ne 0 ]; then
    echo -e "\e[1;31mFEHLER: Dieses Skript muss als root gestartet werden.\e[0m"
    echo "Das ist zwingend nötig, da wir den Certbot-Prozess kontrollieren."
    echo -e "Bitte starte es so: \e[1;33msudo ./update_certbot\e[0m"
    exit 1
fi

# Prüfe auf expect
if ! command -v expect &> /dev/null; then
    echo -e "\e[1;31mFEHLER: Das Paket 'expect' fehlt.\e[0m"
    echo "Das Skript benötigt dieses Werkzeug, um die Zertifikate parallel zu sammeln."
    echo "Bitte installiere es einmalig mit folgendem Befehl:"
    echo -e "\e[1;33msudo apt-get update && sudo apt-get install -y expect\e[0m"
    exit 1
fi

# --- AUTO-FIX FÜR WINDOWS ZEILENUMBRÜCHE (CRLF -> LF) ---
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
export HOOK_SCRIPT="$SCRIPT_DIR/dns_wait_hook.sh"
export CHECKER_SCRIPT="$SCRIPT_DIR/dns_checker.sh"

fix_windows_newlines() {
    local file="$1"
    if [ -f "$file" ] && grep -q $'\r' "$file" 2>/dev/null; then
        echo -e "\e[1;33m[Fix] Windows-Zeilenumbrüche in '$file' gefunden. Repariere...\e[0m"
        sed -i 's/\r$//' "$file"
        
        if [ "$file" == "$(realpath "$0")" ]; then
            echo -e "\e[1;32m[Neu-Start] Hauptskript wurde repariert, starte neu...\e[0m"
            exec "$0" "$@"
            exit 0
        fi
    fi
}

fix_windows_newlines "$(realpath "$0")"
if [ -f "$HOOK_SCRIPT" ]; then fix_windows_newlines "$HOOK_SCRIPT"; fi
if [ -f "$CHECKER_SCRIPT" ]; then fix_windows_newlines "$CHECKER_SCRIPT"; fi
# --------------------------------------------------------

chmod +x "$HOOK_SCRIPT" 2>/dev/null
chmod +x "$CHECKER_SCRIPT" 2>/dev/null

# Arrays für Domains und Keys
DOMAINS=()
WILDCARDS=()
EXPECTED_KEYS=0

read -p "Gib eine domain ein. " FIRST_DOMAIN
if [ -z "$FIRST_DOMAIN" ]; then
    echo "Keine Domains eingegeben. Skript wird beendet."
    exit 1
fi
DOMAINS+=("$FIRST_DOMAIN")
read -p "Soll für $FIRST_DOMAIN auch eine Wildcard (*.$FIRST_DOMAIN) angefordert werden? (j/n) [n]: " FIRST_WC
if [[ "$FIRST_WC" =~ ^[jJ] ]]; then
    WILDCARDS+=(1)
    EXPECTED_KEYS=$((EXPECTED_KEYS + 2))
else
    WILDCARDS+=(0)
    EXPECTED_KEYS=$((EXPECTED_KEYS + 1))
fi

while true; do
    read -p "Gib eine weitere domain ein. (Oder drücke Enter zum Starten) " NEXT_DOMAIN
    
    if [ -z "$NEXT_DOMAIN" ]; then
        echo -e "\nKeine weitere Domain erforderlich. Starte den Prozess..."
        break
    fi
    DOMAINS+=("$NEXT_DOMAIN")
    
    read -p "Soll für $NEXT_DOMAIN auch eine Wildcard (*.$NEXT_DOMAIN) angefordert werden? (j/n) [n]: " NEXT_WC
    if [[ "$NEXT_WC" =~ ^[jJ] ]]; then
        WILDCARDS+=(1)
        EXPECTED_KEYS=$((EXPECTED_KEYS + 2))
    else
        WILDCARDS+=(0)
        EXPECTED_KEYS=$((EXPECTED_KEYS + 1))
    fi
done

# Temp-Dateien für die gesammelten Keys und Signale vorbereiten
rm -f /tmp/certbot_check_list.txt
touch /tmp/certbot_check_list.txt
rm -f /tmp/certbot_all_clear

echo -e "\n\e[1;36m========================================================\e[0m"
echo -e "\e[1;36m      Start isolierter Certbot-Instanzen im Hintergrund \e[0m"
echo -e "\e[1;36m========================================================\e[0m\n"

# Baue eine Expect-Vorlage, die wir für jeden Job nutzen
cat << 'EOF' > /tmp/certbot_runner.exp
set timeout -1
set cmd_args [split $argv " "]
eval spawn certbot $cmd_args

expect {
    -re "Select the appropriate number.*?press 'c' to cancel.*?: " {
        send "2\r"
        exp_continue
    }
    -re "\\(U\\)pdate certificate/\\(C\\)ancel: " {
        send "u\r"
        exp_continue
    }
    -re "Press Enter to Continue" {
        # PAUSE: Warte auf das "ALL CLEAR" Signal vom Hauptskript
        while {![file exists "/tmp/certbot_all_clear"]} {
            sleep 1
        }
        send "\r"
        exp_continue
    }
    eof {
        exit 0
    }
}
EOF

# Starte für jede Domain einen EIGENEN Expect-Job im Hintergrund
PIDS=()
for i in "${!DOMAINS[@]}"; do
    DOM="${DOMAINS[$i]}"
    WC="${WILDCARDS[$i]}"
    
    ARGS="certonly --manual --cert-name $DOM --expand"
    if [ "$WC" -eq 1 ]; then
        ARGS="$ARGS -d *.$DOM -d $DOM"
    else
        ARGS="$ARGS -d $DOM"
    fi
    ARGS="$ARGS --agree-tos --preferred-challenges dns-01 --server https://acme-v02.api.letsencrypt.org/directory --register-unsafely-without-email --rsa-key-size 4096 --manual-auth-hook $HOOK_SCRIPT --debug-challenges"
    
    # Ausführen im Hintergrund
    expect -f /tmp/certbot_runner.exp $ARGS > /dev/null 2>&1 &
    PIDS+=($!)
    echo "-> Job für $DOM gestartet (PID: ${!})..."
done

echo -e "\nWarte, bis alle $EXPECTED_KEYS Schlüssel generiert wurden..."

# Hauptschleife: Warte bis alle Keys da sind
while true; do
    actual_keys=$(wc -l < /tmp/certbot_check_list.txt)
    
    # Prüfe, ob Jobs ggf. gestorben sind (verhindert Endlosschleife bei Fehlern)
    alive_jobs=0
    for pid in "${PIDS[@]}"; do
        if kill -0 $pid 2>/dev/null; then
            alive_jobs=$((alive_jobs + 1))
        fi
    done
    
    if [ "$alive_jobs" -eq 0 ] && [ "$actual_keys" -lt "$EXPECTED_KEYS" ]; then
        echo -e "\n\e[1;31m[FEHLER] Alle Hintergrund-Jobs sind gestorben, bevor die Keys gesammelt wurden.\e[0m"
        echo "Wahrscheinlich kam eine unerwartete Certbot-Abfrage oder ein Rate-Limit."
        exit 1
    fi

    if [ "$actual_keys" -ge "$EXPECTED_KEYS" ]; then
        break
    fi
    sleep 1
done

echo -e "\n\e[1;36m========================================================\e[0m"
echo -e "\e[1;36m ALLE SCHLÜSSEL WURDEN GENERIERT UND GESAMMELT!\e[0m"
echo -e "\e[1;36m Bitte trage nun ALLE Keys in Ruhe bei deinem Provider ein.\e[0m"
echo -e "\e[1;36m========================================================\e[0m\n"

# Liste die Keys für den User auf (Hübsch formatiert)
while read -r domain validation; do
    echo -e "Host: \e[1;36m$domain\e[0m"
    echo -e "Wert: \e[1;36m$validation\e[0m"
    echo "--------------------------------------------------------"
done < /tmp/certbot_check_list.txt

# Rufe nun den Checker auf. Dieser blockiert, bis alles grün ist.
"$CHECKER_SCRIPT"
CHECK_RESULT=$?

if [ $CHECK_RESULT -eq 0 ]; then
    echo -e "\n\e[1;32mGebe grünes Licht an alle Certbot-Instanzen für die Ausstellung...\e[0m"
    # Signal-Datei erstellen, damit die wait-Schleifen der Hintergrund-Expect-Jobs weiterlaufen
    touch /tmp/certbot_all_clear
    
    # Warten, bis alle Jobs final abgearbeitet haben
    wait "${PIDS[@]}"
    
    echo -e "\n\e[1;32mZertifizierungs-Prozesse erfolgreich beendet!\e[0m"
    
    echo -e "\n\e[1;36m========================================================\e[0m"
    echo -e "\e[1;36m Lade Webserver neu & Prüfe Live-Zertifikate...\e[0m"
    echo -e "\e[1;36m========================================================\e[0m"
    
    if systemctl is-active --quiet apache2; then
        echo -n "Lade Apache2 neu... "
        sudo systemctl reload apache2
        echo -e "\e[1;32mOK\e[0m"
        sleep 2
    elif systemctl is-active --quiet nginx; then
        echo -n "Lade Nginx neu... "
        sudo systemctl reload nginx
        echo -e "\e[1;32mOK\e[0m"
        sleep 2
    else
        echo -e "\e[1;33mBeachte: Weder Apache2 noch Nginx gefunden. Bitte manuell neu laden!\e[0m"
    fi
    
    echo -e "\n\e[1;34m--- Live-Check im Internet ---\e[0m"
    for DOM in "${DOMAINS[@]}"; do
        echo -n "Prüfe $DOM... "
        EXPIRY_DATE=$(echo | openssl s_client -servername "$DOM" -connect "${DOM}:443" 2>/dev/null | openssl x509 -noout -enddate 2>/dev/null | cut -d= -f2)
        if [ -n "$EXPIRY_DATE" ]; then
            FORMATTED_DATE=$(date -d "$EXPIRY_DATE" '+%d.%m.%Y' 2>/dev/null || echo "$EXPIRY_DATE")
            echo -e "\e[1;32mONLINE! Gültig bis: $FORMATTED_DATE\e[0m"
        else
            echo -e "\e[1;31mVerbindung fehlgeschlagen (Port 443 zu?)\e[0m"
        fi
    done
    
else
    echo -e "\n\e[1;31mDer DNS Check wurde abgebrochen.\e[0m"
    kill "${PIDS[@]}" 2>/dev/null
    exit 1
fi
