#!/bin/bash
# Hauptskript zum Erneuern/Holen von Let's Encrypt Zertifikaten (SEQUENTIELLE VERSION / LÖSUNG C)
# Version: 1.7

# Prüfe auf Root Rechte
if [ "$EUID" -ne 0 ]; then
    echo -e "\e[1;31mFEHLER: Dieses Skript muss als root gestartet werden.\e[0m"
    echo "Das ist zwingend nötig, da wir den Certbot-Prozess kontrollieren."
    echo -e "Bitte starte es so: \e[1;33msudo ./update_certbot\e[0m"
    exit 1
fi

# Prüfe auf expect
if ! command -v expect &> /dev/null; then
    echo -e "\e[1;31mFEHLER: Das Paket 'expect' fehlt.\e[0m"
    echo "Das Skript benötigt dieses Werkzeug, um die Zertifikate parallel zu sammeln."
    echo "Bitte installiere es einmalig mit folgendem Befehl:"
    echo -e "\e[1;33msudo apt-get update && sudo apt-get install -y expect\e[0m"
    exit 1
fi

# --- AUTO-FIX FÜR WINDOWS ZEILENUMBRÜCHE (CRLF -> LF) ---
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
export HOOK_SCRIPT="$SCRIPT_DIR/dns_wait_hook.sh"
export CHECKER_SCRIPT="$SCRIPT_DIR/dns_checker.sh"

fix_windows_newlines() {
    local file="$1"
    if [ -f "$file" ] && grep -q $'\r' "$file" 2>/dev/null; then
        echo -e "\e[1;33m[Fix] Windows-Zeilenumbrüche in '$file' gefunden. Repariere...\e[0m"
        sed -i 's/\r$//' "$file"
        
        # Falls _dieses_ Skript repariert wurde, muss es sich selbst neu starten
        if [ "$file" == "$(realpath "$0")" ]; then
            echo -e "\e[1;32m[Neu-Start] Hauptskript wurde repariert, starte neu...\e[0m"
            exec "$0" "$@"
            exit 0
        fi
    fi
}

fix_windows_newlines "$(realpath "$0")"
if [ -f "$HOOK_SCRIPT" ]; then fix_windows_newlines "$HOOK_SCRIPT"; fi
if [ -f "$CHECKER_SCRIPT" ]; then fix_windows_newlines "$CHECKER_SCRIPT"; fi
# --------------------------------------------------------

chmod +x "$HOOK_SCRIPT" 2>/dev/null
chmod +x "$CHECKER_SCRIPT" 2>/dev/null

# Array für Domains und ihr Zertifikat-Modus (0=Root, 1=Root+www, 2=Wildcard)
DOMAINS=()
WILDCARDS=()

ask_cert_mode() {
    local dom="$1"
    echo -e "\nWelches Zertifikat soll für \e[1;36m$dom\e[0m ausgestellt werden?"
    echo -e "  \e[1;32m[1]\e[0m Nur Root-Domain       → $dom                    \e[2m(1 TXT-Eintrag)\e[0m"
    echo -e "  \e[1;33m[2]\e[0m Root + www             → $dom + www.$dom         \e[2m(2 TXT-Einträge)\e[0m"
    echo -e "  \e[1;35m[3]\e[0m Wildcard (empfohlen)   → *.$dom + $dom           \e[2m(2 TXT-Einträge, alles abgedeckt)\e[0m"
    while true; do
        read -p "Auswahl [1/2/3]: " MODE_CHOICE
        case "$MODE_CHOICE" in
            1) echo 0; return ;;
            2) echo 1; return ;;
            3) echo 2; return ;;
            *) echo -e "\e[1;31mBitte 1, 2 oder 3 eingeben.\e[0m" ;;
        esac
    done
}

read -p "Gib eine domain ein. " FIRST_DOMAIN
if [ -z "$FIRST_DOMAIN" ]; then
    echo "Keine Domains eingegeben. Skript wird beendet."
    exit 1
fi
DOMAINS+=("$FIRST_DOMAIN")
WILDCARDS+=("$(ask_cert_mode "$FIRST_DOMAIN")")

while true; do
    echo ""
    read -p "Gib eine weitere domain ein. (Oder drücke Enter zum Starten) " NEXT_DOMAIN
    
    if [ -z "$NEXT_DOMAIN" ]; then
        echo -e "\nKeine weitere Domain erforderlich. Starte den Prozess..."
        break
    fi
    DOMAINS+=("$NEXT_DOMAIN")
    WILDCARDS+=("$(ask_cert_mode "$NEXT_DOMAIN")")
done


# ========================================================================
# SCHLEIFE: Zertifikate sequentiell nacheinander abarbeiten
# ========================================================================
for i in "${!DOMAINS[@]}"; do
    DOM="${DOMAINS[$i]}"
    WC="${WILDCARDS[$i]}"
    
    echo -e "\n\e[1;36m========================================================\e[0m"
    echo -e "\e[1;36m    Beginne isolierten Durchlauf für: $DOM    \e[0m"
    echo -e "\e[1;36m========================================================\e[0m\n"

    # Argumente für exakt DIESE eine Domain bauen
    CERTBOT_ARGS="certonly --manual --cert-name $DOM --expand"
    if [ "$WC" -eq 0 ]; then
        # Modus 1: Nur Root-Domain
        CERTBOT_ARGS="$CERTBOT_ARGS -d $DOM"
        echo -e "\e[1;32m>>> Modus: Nur Root-Domain – es wird 1 TXT-Eintrag verlangt. <<<\e[0m"
        echo ""
    elif [ "$WC" -eq 1 ]; then
        # Modus 2: Root + www
        CERTBOT_ARGS="$CERTBOT_ARGS -d $DOM -d www.$DOM"
        echo -e "\e[1;33m>>> Modus: Root + www – es werden 2 TXT-Einträge verlangt. <<<\e[0m"
        echo    "Beide haben unterschiedliche Hostnamen: _acme-challenge.$DOM und _acme-challenge.www.$DOM"
        echo ""
    else
        # Modus 3: Wildcard
        CERTBOT_ARGS="$CERTBOT_ARGS -d *.$DOM -d $DOM"
        echo -e "\e[1;35m>>> Modus: Wildcard (*.$DOM) – es werden 2 TXT-Einträge verlangt. <<<\e[0m"
        echo -e "Beide haben den \e[1;31mGLEICHEN Hostnamen\e[0m (_acme-challenge.$DOM), aber unterschiedliche Werte!"
        echo -e "Trage \e[1;32mbeiden Werte nacheinander\e[0m bei deinem Provider ein (zweimal 'Hinzufügen' klicken)."
        echo ""
    fi
    CERTBOT_ARGS="$CERTBOT_ARGS --agree-tos --preferred-challenges dns-01 --server https://acme-v02.api.letsencrypt.org/directory --register-unsafely-without-email --rsa-key-size 4096 --manual-auth-hook $HOOK_SCRIPT --debug-challenges"
    export CERTBOT_ARGS

    # Temp-Datei für die gesammelten Keys der AKTUELLEN Domain vorbereiten
    rm -f /tmp/certbot_check_list.txt
    touch /tmp/certbot_check_list.txt

    # Der intelligente Expect-Wrapper
    expect_script=$(cat << 'EOF'
set timeout -1
# Argumente sauber splitten, damit keine Leerzeichenprobleme entstehen
set cmd_args [split $env(CERTBOT_ARGS) " "]
eval spawn certbot $cmd_args

# Fange Ctrl+C ab, damit expect nicht den ekligen Stacktrace wirft
trap {
    send_user "\n\033\[1;31m[ABBRUCH] Prozess durch Benutzer (Ctrl+C) abgebrochen!\033\[0m\n"
    exit 2
} SIGINT

expect {
    -re "Select the appropriate number.*?press 'c' to cancel.*?: " {
        # Falls Certbot fragt ob wir behalten oder erneuern wollen (exakt gleiche Domains)
        send "2\r"
        exp_continue
    }
    -re "\\(U\\)pdate certificate/\\(C\\)ancel: " {
        # Falls Certbot meckert, dass Domains entfernt oder verändert wurden
        send "u\r"
        exp_continue
    }
    -re "Press Enter to Continue" {
        # CERTBOT PAUSIERT NUN. ALLE KEYS SIND OBEN SICHTBAR.
        # Wir rufen jetzt unser Bash-Checker-Skript auf,
        # dieses blockiert so lange, bis Google und Cloudflare für ALLE Keys grün geben.
        
        # Falls das Checker-Skript mit Fehler beendet wird (z.B. durch Ctrl+C), 
        # fangen wir das hier auf.
        if {[catch {system "$env(CHECKER_SCRIPT)"} result]} {
            send_user "\n\033\[1;31m[ABBRUCH] Checker-Skript wurde abgebrochen.\033\[0m\n"
            exit 2
        }
        
        # Sobald das Skript erfolgreich zurückkehrt, drücken wir Enter!
        send "\r"
        exp_continue
    }
    eof {
        # Certbot ist komplett fertig.
        exit 0
    }
}
EOF
)

    # Expect ausführen
    expect -c "$expect_script"
    EXIT_CODE=$?

    if [ $EXIT_CODE -ne 0 ]; then
        echo -e "\n\e[1;31mDer Prozess für $DOM ist fehlgeschlagen! Breche Gesamtlauf ab.\e[0m"
        exit 1
    fi
    
    echo -e "\n\e[1;32mZertifikat für $DOM erfolgreich bezogen!\e[0m"
    sleep 2 # Kurze Pause zur besseren Lesbarkeit bevor die nächste Domain dran ist
done

echo -e "\n\e[1;36m========================================================\e[0m"
echo -e "\e[1;36m Lade Webserver neu & Prüfe Live-Zertifikate...\e[0m"
echo -e "\e[1;36m========================================================\e[0m"

# Apache/Nginx GEMEINSAM am Ende neu laden
if systemctl is-active --quiet apache2; then
    echo -n "Lade Apache2 neu... "
    sudo systemctl reload apache2
    echo -e "\e[1;32mOK\e[0m"
    sleep 2 # Gib dem Webserver kurz Zeit
elif systemctl is-active --quiet nginx; then
    echo -n "Lade Nginx neu... "
    sudo systemctl reload nginx
    echo -e "\e[1;32mOK\e[0m"
    sleep 2
else
    echo -e "\e[1;33mBeachte: Weder Apache2 noch Nginx gefunden. Bitte Webserver manuell neu laden!\e[0m"
fi

# Jede nackte Domain live via openSSL prüfen
echo -e "\n\e[1;34m--- Live-Check im Internet ---\e[0m"
for DOM in "${DOMAINS[@]}"; do
    echo -n "Prüfe $DOM... "
    # Hole das Datum der Live-Webseite
    EXPIRY_DATE=$(echo | openssl s_client -servername "$DOM" -connect "${DOM}:443" 2>/dev/null | openssl x509 -noout -enddate 2>/dev/null | cut -d= -f2)
    
    if [ -n "$EXPIRY_DATE" ]; then
        # Parse Datum schöner (z.B. von "May  6 15:33:20 2026 GMT" zu "06.05.2026")
        FORMATTED_DATE=$(date -d "$EXPIRY_DATE" '+%d.%m.%Y' 2>/dev/null || echo "$EXPIRY_DATE")
        echo -e "\e[1;32mONLINE! Gültig bis: $FORMATTED_DATE\e[0m"
    else
        echo -e "\e[1;31mVerbindung fehlgeschlagen (Port 443 zu?)\e[0m"
    fi
done
echo ""

